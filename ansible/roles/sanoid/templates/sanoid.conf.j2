# ============================================================
# /etc/sanoid/sanoid.conf — managed by Ansible role: sanoid
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/sanoid/defaults/main.yml
# Re-deploy with:
#   ansible-playbook site.yml -l hypervisor_hosts --tags sanoid
#
# Sanoid documentation:
#   https://github.com/jimsalterjrs/sanoid
# ============================================================

{% for ds in sanoid_datasets %}
[{{ ds.dataset }}]
    use_template = {{ ds.template }}
    recursive = {{ ds.recursive }}

{% endfor %}
{% for name, policy in sanoid_templates.items() %}
[template_{{ name }}]
    hourly = {{ policy.hourly }}
    daily = {{ policy.daily }}
    weekly = {{ policy.weekly }}
    monthly = {{ policy.monthly }}
{% if policy.yearly is defined %}
    yearly = {{ policy.yearly }}
{% endif %}
    autosnap = yes
    autoprune = yes

{% endfor %}
