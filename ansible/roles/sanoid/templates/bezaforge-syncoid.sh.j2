#!/usr/bin/env bash
# ============================================================
# bezaforge-syncoid.sh — managed by Ansible role: sanoid
#
# Nightly cross-pool ZFS replication (FORGE-85 / ADR 0003).
# Local send/recv only — both ends are pools on this host, so
# no SSH hop. Replicates sanoid's snapshots (--no-sync-snap)
# and prunes the target in lockstep with the source
# (--delete-target-snapshots) so replicas never pin expired
# snapshots (FORGE-44).
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/sanoid/templates/bezaforge-syncoid.sh.j2
# ============================================================

set -uo pipefail

rc=0
{% for repl in sanoid_syncoid_replications %}
echo "==> syncoid {{ repl.src }} -> {{ repl.dest }} ($(date -u +%Y-%m-%dT%H:%M:%SZ))"
if ! /usr/sbin/syncoid \
    --no-sync-snap \
    --delete-target-snapshots \
    "{{ repl.src }}" "{{ repl.dest }}"; then
    echo "syncoid {{ repl.src }} -> {{ repl.dest }} FAILED" >&2
    rc=1
fi
{% endfor %}

if [ "$rc" -ne 0 ]; then
    echo "One or more replications FAILED" >&2
    exit 1
fi
echo "All replications completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
