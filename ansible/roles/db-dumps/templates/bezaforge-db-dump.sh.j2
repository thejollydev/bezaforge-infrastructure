#!/usr/bin/env bash
# ============================================================
# bezaforge-db-dump.sh — managed by Ansible role: db-dumps
#
# Runs nightly via systemd timer. For each configured Postgres
# container, executes pg_dumpall as the superuser via docker
# exec (uses local Unix socket auth — no password needed).
# Output is gzipped and written to
# {{ backup_root }}/<service>/dumps/<UTC-iso8601>.sql.gz.
#
# Old dumps are pruned to keep the newest {{ dump_retention_count }}
# files per service. Sanoid snapshots provide longer retention.
#
# Exit code is non-zero if ANY dump fails — systemd records
# this as a unit failure, which Prometheus can alert on via
# node_exporter's systemd collector.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/db-dumps/templates/bezaforge-db-dump.sh.j2
# ============================================================

set -uo pipefail

BACKUP_ROOT="{{ backup_root }}"
RETENTION="{{ dump_retention_count }}"
TS="$(date -u +%Y-%m-%dT%H-%M-%SZ)"

failed=0

# Quick sanity check: the NFS mount must be live. If it's not
# mounted, we'd silently write to a local directory that doesn't
# get backed up — worse than failing loudly.
if ! mountpoint -q "${BACKUP_ROOT}"; then
    echo "FATAL: ${BACKUP_ROOT} is not a mountpoint. NFS down?" >&2
    exit 2
fi

{% for entry in postgres_dumps %}
# --- {{ entry.service }} ({{ entry.container }}) ---
{
    svc_dir="${BACKUP_ROOT}/{{ entry.service }}/dumps"
    mkdir -p "${svc_dir}"
    target="${svc_dir}/${TS}.sql.gz"
    # Auto-discover the superuser from the container's env. Every
    # official postgres image sets POSTGRES_USER to whatever superuser
    # was bootstrapped at first init. Falling back to "postgres" is
    # the documented default if the var is unset (which the
    # docker-entrypoint also assumes).
    superuser="$(docker exec {{ entry.container }} sh -c 'echo "${POSTGRES_USER:-postgres}"' 2>/dev/null)"
    if [[ -z "${superuser}" ]]; then
        echo "FAIL {{ entry.service }} ({{ entry.container }}) — could not read POSTGRES_USER from container" >&2
        failed=1
    elif docker exec {{ entry.container }} pg_dumpall -U "${superuser}" 2>/tmp/bezaforge-db-dump-{{ entry.container }}.err \
        | gzip -c > "${target}.partial"; then
        mv "${target}.partial" "${target}"
        echo "OK   {{ entry.service }} → ${target} ($(stat -c %s "${target}" | numfmt --to=iec)) [user=${superuser}]"
        # Prune older dumps beyond retention.
        ls -1t "${svc_dir}"/*.sql.gz 2>/dev/null \
            | tail -n +$((RETENTION + 1)) \
            | xargs --no-run-if-empty rm --
    else
        echo "FAIL {{ entry.service }} ({{ entry.container }}) [user=${superuser}]" >&2
        cat /tmp/bezaforge-db-dump-{{ entry.container }}.err >&2 || true
        rm -f "${target}.partial"
        failed=1
    fi
}
{% endfor %}

if [[ ${failed} -ne 0 ]]; then
    echo "One or more dumps failed — see above." >&2
    exit 1
fi
echo "All dumps completed at ${TS}."
