# Brizza Postgres .env — rendered from roles/brizza-postgres/templates/env.j2
# Secret sourced from ansible-vault (host_vars/forge-ops/vault.yml).
#
# docker-compose interpolates ${BRIZZA_DB_PASSWORD} into the
# brizza-db POSTGRES_PASSWORD on first init. Brizza itself builds
# its connection string from this same password on forge-brizza:
#   postgres://brizza:<pw>@10.10.20.20:5432/brizza
BRIZZA_DB_PASSWORD={{ brizza_db_password }}
