# Plane .env — rendered from roles/plane/templates/env.j2
# Secrets sourced from ansible-vault (host_vars/forge-ops/vault.yml).

# --- Upstream release pin ---
# All 6 makeplane/* images share this tag.
APP_RELEASE={{ plane_release }}

# --- Public URL ---
APP_DOMAIN={{ plane_host }}
WEB_URL={{ plane_url }}
CORS_ALLOWED_ORIGINS={{ plane_url }}

# --- Postgres ---
POSTGRES_PASSWORD={{ plane_db_password }}

# --- RabbitMQ ---
RABBITMQ_PASSWORD={{ plane_rabbitmq_password }}

# --- App secrets ---
# Django SECRET_KEY (>=50 chars random) and LIVE_SERVER_SECRET_KEY (32+ chars).
SECRET_KEY={{ plane_secret_key }}
LIVE_SERVER_SECRET_KEY={{ plane_live_server_secret_key }}

# --- MinIO (bundled object storage; not externally exposed) ---
USE_MINIO=1
AWS_ACCESS_KEY_ID={{ plane_minio_access_key }}
AWS_SECRET_ACCESS_KEY={{ plane_minio_secret_key }}

# --- Proxy ---
# The plane-proxy container only listens on its container ports; Traefik
# fronts it. These vars stay at defaults but the proxy expects them set.
FILE_SIZE_LIMIT=5242880

# Plane-proxy is Caddy. We don't want it doing TLS — Traefik handles that.
# But Caddy still parses its global block at startup, and `acme_ca` requires
# a non-empty value even when it'll never run (because SITE_ADDRESS=:80
# is plain HTTP only). Default Let's Encrypt URL satisfies the parser.
# Caught 2026-05-22 — plane-proxy was restart-looping on `parsing caddyfile
# tokens for 'acme_ca': wrong argument count` until this was set.
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory

# --- Misc ---
DEBUG=0
GUNICORN_WORKERS=1
