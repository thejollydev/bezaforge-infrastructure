# Outline .env — rendered from roles/outline/templates/env.j2
# Secrets sourced from ansible-vault (host_vars/forge-ops/vault.yml).

# --- Core ---
URL={{ outline_url }}
PORT=3000
SECRET_KEY={{ outline_secret_key }}
UTILS_SECRET={{ outline_utils_secret }}

# --- Data ---
# OUTLINE_DB_PASSWORD is read by docker-compose to interpolate
# ${OUTLINE_DB_PASSWORD} in the postgres service block; DATABASE_URL
# is what Outline itself reads.
OUTLINE_DB_PASSWORD={{ outline_db_password }}
DATABASE_URL=postgres://outline:{{ outline_db_password }}@outline-db:5432/outline
PGSSLMODE=disable
REDIS_URL=redis://outline-redis:6379

# --- File storage (local FS — bind-mounted to /opt/bezaforge/outline/uploads) ---
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE={{ outline_file_storage_max_size }}

# --- Auth (Google Workspace OIDC) ---
# Generic OIDC provider against Google's discovery endpoints.
# Workspace restriction to bezacore.com is enforced in the
# Google Cloud Console OAuth client config, not here.
OIDC_CLIENT_ID={{ outline_oidc_client_id }}
OIDC_CLIENT_SECRET={{ outline_oidc_client_secret }}
OIDC_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
OIDC_TOKEN_URI=https://oauth2.googleapis.com/token
OIDC_USERINFO_URI=https://openidconnect.googleapis.com/v1/userinfo
OIDC_USERNAME_CLAIM=email
OIDC_DISPLAY_NAME=Google
OIDC_SCOPES=openid profile email

# --- Misc ---
# Traefik terminates TLS; Outline sees plain HTTP from the proxy.
FORCE_HTTPS=false
ENABLE_UPDATES=false
LOG_LEVEL=info
DEFAULT_LANGUAGE=en_US
