#!/usr/bin/env bash
# ============================================================
# bezaforge-restic-check.sh — weekly integrity check
#
# `restic check` reads all metadata in the repo and verifies
# it. Doesn't read every data blob (that would be expensive in
# GCS egress) — use `restic check --read-data` quarterly via
# a separate runbook for full verification.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/restic-gcs/templates/bezaforge-restic-check.sh.j2
# ============================================================

set -uo pipefail

# shellcheck disable=SC1091
source /etc/bezaforge/restic.env

echo "==> restic check ($(date -u +%Y-%m-%dT%H:%M:%SZ))"
if ! restic check; then
    echo "restic check FAILED" >&2
    exit 1
fi
echo "Repo integrity OK at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
