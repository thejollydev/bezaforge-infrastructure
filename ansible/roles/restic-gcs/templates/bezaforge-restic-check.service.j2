[Unit]
Description=BezaForge weekly restic repo integrity check
Documentation=https://github.com/thejollydev/bezaforge-infrastructure
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=HOME=/root
ExecStart=/usr/local/bin/bezaforge-restic-check.sh
StandardOutput=journal
StandardError=journal
TimeoutStartSec=1h

[Install]
WantedBy=multi-user.target
