#!/usr/bin/env bash
# ============================================================
# bezaforge-restic-backup.sh — managed by Ansible role: restic-gcs
#
# Daily restic backup of forge-ops-backup → Google Cloud Storage
# Nearline bucket. Followed by restic forget --keep-* for retention.
#
# Environment is sourced from /etc/bezaforge/restic.env (deployed
# by the role, mode 0600) which sets RESTIC_*, GOOGLE_*.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/restic-gcs/templates/bezaforge-restic-backup.sh.j2
# ============================================================

set -uo pipefail

# Load environment (RESTIC_REPOSITORY, RESTIC_PASSWORD_FILE,
# GOOGLE_APPLICATION_CREDENTIALS, GOOGLE_PROJECT_ID).
# shellcheck disable=SC1091
source /etc/bezaforge/restic.env

# ------------------------------------------------------------
# 1. Backup
# ------------------------------------------------------------
echo "==> restic backup ($(date -u +%Y-%m-%dT%H:%M:%SZ))"
if ! restic backup \
    --host "{{ restic_hostname }}" \
    --tag forge-ops-backup \
    --tag adr-0001 \
{% for src in restic_backup_sources %}
    "{{ src }}" \
{% endfor %}
    ; then
    echo "restic backup FAILED" >&2
    exit 1
fi

# ------------------------------------------------------------
# 2. Prune by policy
# ------------------------------------------------------------
echo "==> restic forget --keep-daily {{ restic_keep_daily }} --keep-weekly {{ restic_keep_weekly }} --keep-monthly {{ restic_keep_monthly }} --keep-yearly {{ restic_keep_yearly }}"
if ! restic forget \
    --host "{{ restic_hostname }}" \
    --tag forge-ops-backup \
    --keep-daily {{ restic_keep_daily }} \
    --keep-weekly {{ restic_keep_weekly }} \
    --keep-monthly {{ restic_keep_monthly }} \
    --keep-yearly {{ restic_keep_yearly }} \
    --prune; then
    echo "restic forget FAILED" >&2
    exit 1
fi

echo "==> restic snapshots (post-backup state)"
restic snapshots --host "{{ restic_hostname }}" --tag forge-ops-backup --compact

echo "Backup completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
