# OpenProject .env — rendered from roles/openproject/templates/env.j2
# Secrets sourced from ansible-vault (host_vars/forge-ops/vault.yml).
#
# NOTE: this file feeds TWO consumers:
#   1. docker compose variable interpolation (OPENPROJECT_RELEASE +
#      OPENPROJECT_HOST are read from ./.env for the image tag and
#      the Traefik Host() label).
#   2. the container's environment (env_file), where OpenProject
#      reads its OPENPROJECT_* settings.

# --- compose interpolation ---
OPENPROJECT_RELEASE={{ openproject_release }}
OPENPROJECT_HOST={{ openproject_host }}

# --- app config ---
OPENPROJECT_HOST__NAME={{ openproject_host }}
# TLS terminates at Traefik; force https URL generation + HSTS.
OPENPROJECT_HTTPS=true
OPENPROJECT_HSTS=true

# Rails secret (>= 30 chars random hex). Immutable once set —
# rotating it invalidates sessions/cookies. Must be the RAW Rails
# var name SECRET_KEY_BASE (NOT OPENPROJECT_-prefixed — that prefix
# is only for OpenProject's own settings; the raw name is what the
# entrypoint's insecure-default check reads).
SECRET_KEY_BASE={{ openproject_secret_key_base }}

# Seed the built-in admin on first boot. RESET=false so re-runs
# don't clobber a password you've since changed in the UI.
OPENPROJECT_SEED_ADMIN_USER_PASSWORD={{ openproject_admin_password }}
OPENPROJECT_SEED_ADMIN_USER_PASSWORD__RESET=false

# Modest thread pool for a single-user pilot host.
RAILS_MIN_THREADS=2
RAILS_MAX_THREADS=6
