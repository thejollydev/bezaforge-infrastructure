#!/usr/bin/env bash
# ============================================================
# bezaforge-minio-export.sh — managed by Ansible role: minio-exports
#
# Runs nightly via systemd timer (02:35), between db-dumps (02:30)
# and forge-ops-backup-rsync (02:45). For each configured MinIO
# container it execs `mc mirror` of the bucket into the container's
# /export bind-mount, whose host path (/opt/bezaforge/<svc>/minio)
# is then swept offsite by the rsync role. This is the S3 analog of
# the db-dumps pg_dump: a logical export that keeps the live store
# in its upstream-faithful named volume.
#
# Credentials are read from each container's OWN environment
# (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD) at runtime — never stored
# here — mirroring how db-dumps auto-discovers POSTGRES_USER. The
# single-quoted `sh -c` body is expanded by the CONTAINER shell, not
# the host shell, so the secret never lands in the host process args.
#
# Exit code is non-zero if ANY export fails — systemd records this as
# a unit failure, which Prometheus alerts on via node_exporter's
# systemd collector (same pattern as db-dumps / rsync).
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/minio-exports/templates/bezaforge-minio-export.sh.j2
# ============================================================

set -uo pipefail

# Fixed alias name used only inside the containers' mc config. Named
# distinctly so it never collides with the stock local/play/s3 aliases.
ALIAS="bezaforge-backup"

failed=0

{% for e in minio_exports %}
# --- {{ e.service }} ({{ e.container }} → bucket '{{ e.bucket }}') ---
{
    echo "==> {{ e.service }} ({{ e.container }}, bucket={{ e.bucket }})"
    # `mc mirror --overwrite --remove` makes <export_path> an exact mirror
    # of the bucket (adds/updates changed objects, drops deleted ones) —
    # the rsync --delete / sanoid-snapshots-for-history model. The alias is
    # (re)set every run from the container env so a credential rotation is
    # picked up automatically and no stale alias lingers.
    if docker exec {{ e.container }} sh -c '
            mc alias set "'"${ALIAS}"'" "{{ e.endpoint }}" "$MINIO_ROOT_USER" "$MINIO_ROOT_PASSWORD" >/dev/null &&
            mc mirror --overwrite --remove "'"${ALIAS}"'/{{ e.bucket }}" "{{ e.export_path }}"
        ' 2>/tmp/bezaforge-minio-export-{{ e.container }}.err; then
        echo "OK   {{ e.service }} → {{ e.export_path }} (host: /opt/bezaforge/{{ e.service }}/minio)"
    else
        echo "FAIL {{ e.service }} ({{ e.container }})" >&2
        cat /tmp/bezaforge-minio-export-{{ e.container }}.err >&2 || true
        failed=1
    fi
}
{% endfor %}

if [[ ${failed} -ne 0 ]]; then
    echo "One or more MinIO exports failed — see above." >&2
    exit 1
fi
echo "All MinIO exports completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
