#!/usr/bin/env bash
# ============================================================
# bezaforge-backup-rsync.sh — managed by Ansible role: forge-ops-backup-rsync
#
# Runs nightly via systemd timer AFTER bezaforge-db-dumps.service.
# Mirrors each /opt/bezaforge/<service>/ into
# {{ backup_dest_root }}/<service>/data/ via rsync. Uses --delete
# so the mirror tracks the source — sanoid snapshots provide history.
#
# Exit code is non-zero if ANY service rsync fails. Systemd records
# the unit as failed; Prometheus node_exporter can alert on that.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/forge-ops-backup-rsync/templates/bezaforge-backup-rsync.sh.j2
# ============================================================

set -uo pipefail

SRC_ROOT="{{ backup_source_root }}"
DEST_ROOT="{{ backup_dest_root }}"

# Sanity check: the NFS mount must be live.
if ! mountpoint -q "${DEST_ROOT}"; then
    echo "FATAL: ${DEST_ROOT} is not a mountpoint. NFS down?" >&2
    exit 2
fi

# Baseline excludes that apply to every service.
BASE_EXCLUDES=(
    --exclude='*.tmp'
    --exclude='*.lock'
    --exclude='*.pid'
    --exclude='*.swp'
)

# Common rsync flags.
# -a    : archive (preserve perms, times, symlinks, etc.)
# -H    : preserve hard links
# -X    : preserve extended attributes
# --delete : remove dest files that are gone from source
# --numeric-ids : preserve raw uid/gid (don't try to map names)
# --info=stats1,progress2 : show summary at the end + light progress
RSYNC_FLAGS=(
    -aHX
    --delete
    --numeric-ids
    --info=stats1
)

failed=0

{% for svc in backup_services %}
# --- {{ svc.name }} ---
{
    src="${SRC_ROOT}/{{ svc.name }}/"
    dest="${DEST_ROOT}/{{ svc.name }}/data/"
    if [[ ! -d "${src}" ]]; then
        echo "SKIP {{ svc.name }} — ${src} does not exist"
    else
        mkdir -p "${dest}"
        echo "==> {{ svc.name }}"
        if rsync "${RSYNC_FLAGS[@]}" "${BASE_EXCLUDES[@]}" \
{% for excl in svc.excludes | default([]) %}
            --exclude='{{ excl }}' \
{% endfor %}
            "${src}" "${dest}"; then
            echo "OK   {{ svc.name }}"
        else
            echo "FAIL {{ svc.name }} (rsync exit $?)" >&2
            failed=1
        fi
    fi
}
{% endfor %}

if [[ ${failed} -ne 0 ]]; then
    echo "One or more rsyncs failed — see above." >&2
    exit 1
fi
echo "All rsyncs completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
