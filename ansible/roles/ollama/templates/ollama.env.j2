{{ ansible_managed | comment }}
# /etc/default/ollama — sourced by ollama.service via the
# role's systemd drop-in. All knobs here flow from
# ansible/roles/ollama/defaults/main.yml (override per-host
# in inventory/host_vars/<host>.yml).

OLLAMA_HOST={{ ollama_host }}
OLLAMA_MODELS={{ ollama_models_dir }}
OLLAMA_KEEP_ALIVE={{ ollama_keep_alive }}
OLLAMA_MAX_LOADED_MODELS={{ ollama_max_loaded_models }}
{% if ollama_hsa_override_gfx_version | length > 0 %}
HSA_OVERRIDE_GFX_VERSION={{ ollama_hsa_override_gfx_version }}
{% endif %}
{% for key, value in (ollama_extra_env | default({})).items() %}
{{ key }}={{ value }}
{% endfor %}
