# Cognee .env — rendered from roles/cognee/templates/env.j2
# Secret sourced from ansible-vault (host_vars/forge-ops/vault.yml).
#
# docker-compose interpolates ${COGNEE_API_TOKEN} into cognee-mcp's
# API_TOKEN. This is the MCP->backend token (cognee-mcp authenticating
# to the cognee backend), NOT client-facing auth — clients reach the
# MCP endpoint over the network via Traefik, gated by network isolation.
COGNEE_API_TOKEN={{ cognee_api_token }}
# Gemini API key for the extraction LLM (paid tier = no-train).
# docker-compose interpolates ${COGNEE_GEMINI_API_KEY} into the backend's
# LLM_API_KEY. Sourced from ansible-vault (host_vars/forge-ops/vault.yml).
COGNEE_GEMINI_API_KEY={{ vault_cognee_gemini_api_key }}
