networks:
  {{ cognee_network }}:
    external: true

services:
  cognee:
    image: {{ cognee_image }}
    container_name: cognee
    restart: unless-stopped
    environment:
      - HOST=0.0.0.0
      - ENVIRONMENT=production
      - LOG_LEVEL=INFO
      - TELEMETRY_DISABLED=true
      - LLM_PROVIDER={{ cognee_llm_provider }}
      - LLM_MODEL={{ cognee_llm_model }}
      - LLM_API_KEY=${COGNEE_GEMINI_API_KEY}
      - EMBEDDING_PROVIDER=ollama
      - EMBEDDING_MODEL={{ cognee_embedding_model }}
      - EMBEDDING_ENDPOINT={{ cognee_embedding_endpoint }}
      - EMBEDDING_DIMENSIONS={{ cognee_embedding_dimensions }}
      - EMBEDDING_API_KEY=ollama
      - HUGGINGFACE_TOKENIZER={{ cognee_hf_tokenizer }}
      - EMBEDDING_RATE_LIMIT_ENABLED=true
      - EMBEDDING_RATE_LIMIT_REQUESTS={{ cognee_rate_limit_requests }}
      - EMBEDDING_RATE_LIMIT_INTERVAL={{ cognee_rate_limit_interval }}
      - LLM_RATE_LIMIT_ENABLED=true
      - LLM_RATE_LIMIT_REQUESTS={{ cognee_rate_limit_requests }}
      - LLM_RATE_LIMIT_INTERVAL={{ cognee_rate_limit_interval }}
      - DB_PROVIDER=sqlite
      - VECTOR_DB_PROVIDER=lancedb
      - GRAPH_DATABASE_PROVIDER=kuzu
      - DATA_ROOT_DIRECTORY=/data
      - SYSTEM_ROOT_DIRECTORY=/system
    volumes:
      - {{ bezaforge_root }}/cognee/data:/data
      - {{ bezaforge_root }}/cognee/system:/system
      - {{ cognee_vault_mount }}:/vault:ro
    networks:
      - {{ cognee_network }}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  cognee-mcp:
    image: {{ cognee_mcp_image }}
    container_name: cognee-mcp
    restart: unless-stopped
    depends_on:
      cognee:
        condition: service_healthy
    environment:
      - TRANSPORT_MODE=http
      - HOST=0.0.0.0
      - PORT=8000
      - API_URL=http://cognee:8000
      - API_TOKEN=${COGNEE_API_TOKEN}
      - MCP_ALLOWED_HOSTS={{ cognee_hostname }}
      - LOG_LEVEL=INFO
    networks:
      - {{ cognee_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.cognee-mcp.rule=Host(`{{ cognee_hostname }}`)"
      - "traefik.http.routers.cognee-mcp.entrypoints=websecure"
      - "traefik.http.routers.cognee-mcp.tls.certresolver=letsencrypt"
      - "traefik.http.services.cognee-mcp.loadbalancer.server.port=8000"
