networks:
  bezaforge-net:
    external: true

services:
  gitea-db:
    image: postgres:15-alpine@sha256:3d0f7584ed7d04e27fa050d6683a74746608faf21f202be78460d679cc56461f
    container_name: gitea-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: gitea
      POSTGRES_USER: gitea
      POSTGRES_PASSWORD: {{ gitea_db_password }}
    volumes:
      - /opt/bezaforge/gitea/postgres:/var/lib/postgresql/data
    networks:
      - bezaforge-net

  gitea:
    image: gitea/gitea:1.27.0@sha256:7dff60d7ea6df9d0bdf78971cdb1350e9b7df3fda5f115c77afe12122887bd64
    container_name: gitea
    restart: unless-stopped
    depends_on:
      - gitea-db
    environment:
      - USER_UID=1000
      - USER_GID=1000
      - GITEA__database__DB_TYPE=postgres
      - GITEA__database__HOST=gitea-db:5432
      - GITEA__database__NAME=gitea
      - GITEA__database__USER=gitea
      - GITEA__database__PASSWD={{ gitea_db_password }}
      - GITEA__server__DOMAIN=git.{{ domain }}
      - GITEA__server__ROOT_URL=https://git.{{ domain }}
      - GITEA__server__SSH_DOMAIN=git.{{ domain }}
      # Push-to-create: `git push <new-url>` auto-creates the repo under
      # the user's namespace. Default visibility is private — toggle in
      # the Gitea UI if a repo should be public.
      - GITEA__repository__ENABLE_PUSH_CREATE_USER=true
      - GITEA__repository__ENABLE_PUSH_CREATE_ORG=true
      - GITEA__repository__DEFAULT_PUSH_CREATE_PRIVATE=true
      # Webhooks to private IPs are denied by default (SSRF guard).
      # Allowlist exactly the vault-sync receiver on forge-hypervisor
      # (ADR 0002 v1.2 — Gitea push → dataset-owner pulls within seconds).
      - GITEA__webhook__ALLOWED_HOST_LIST=10.10.10.10
    volumes:
      - /opt/bezaforge/gitea/data:/data
    ports:
      - "{{ production_ip }}:2222:22"
    networks:
      - bezaforge-net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.gitea.rule=Host(`git.{{ domain }}`)"
      - "traefik.http.routers.gitea.entrypoints=websecure"
      - "traefik.http.routers.gitea.tls.certresolver=letsencrypt"
      - "traefik.http.services.gitea.loadbalancer.server.port=3000"
