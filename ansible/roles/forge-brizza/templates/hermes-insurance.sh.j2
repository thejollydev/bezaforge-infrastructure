#!/usr/bin/env bash
# {{ ansible_managed }}
# hermes-insurance — Brizza portability guardrail (BRIZZA-58).
#
# Nightly, via hermes-insurance.timer:
#   1. `hermes sessions export`  → dated JSONL (the ADR 0001 "insurance
#      jsonl", native in Hermes 0.16 — full conversation transcripts,
#      replayable into any future memory backend at graduation).
#   2. `hermes backup -q`        → consistent state SNAPSHOT directory
#      (config, state.db, auth, cron, gateway_state; ~7 MB). state.db is
#      live SQLite-WAL; a raw rsync of it can capture a torn copy — these
#      snapshots are the consistent artifact the FORGE-25 off-VM backup
#      carries. ⚠ Quick mode IGNORES -o and always writes to
#      <state-dir>/state-snapshots/<ts>-<label>/ (verified 2026-06-11).
#   3. Prune both stores past the retention window.
#
# Bare-metal since BRIZZA-66 (Docker→bare-metal, 2026-06-16): calls
# `hermes` DIRECTLY as {{ forge_brizza_docker_user }}, not via
# `docker exec` (BRIZZA-73 — the old container wrapper failed every night
# once the `hermes` container was gone). HERMES is the absolute launcher
# path because ~/.local/bin is NOT on the systemd unit's PATH.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/forge-brizza/templates/hermes-insurance.sh.j2
set -euo pipefail

HERMES="{{ forge_brizza_hermes_bin }}"
STATE_DIR="{{ forge_brizza_hermes_state_dir }}"
EXPORTS="${STATE_DIR}/exports"
SNAPSHOTS="${STATE_DIR}/state-snapshots"
RETENTION={{ forge_brizza_hermes_insurance_retention_days }}
ts=$(date +%F)

mkdir -p "${EXPORTS}"

"${HERMES}" sessions export "${EXPORTS}/sessions-${ts}.jsonl"
"${HERMES}" backup -q -l nightly

# Exports are flat files; state snapshots are per-run directories.
find "${EXPORTS}" -maxdepth 1 -type f -mtime +"${RETENTION}" -delete
find "${SNAPSHOTS}" -mindepth 1 -maxdepth 1 -type d -mtime +"${RETENTION}" -exec rm -rf {} +

logger -t hermes-insurance "ok: sessions-${ts}.jsonl + state snapshot 'nightly' (exports $(du -sh "${EXPORTS}" | cut -f1), snapshots $(du -sh "${SNAPSHOTS}" | cut -f1))"
