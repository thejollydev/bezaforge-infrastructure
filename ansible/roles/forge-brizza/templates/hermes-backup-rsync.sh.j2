#!/usr/bin/env bash
# {{ ansible_managed }}
# hermes-backup-rsync — Brizza off-VM durability (FORGE-25).
#
# Nightly, via hermes-backup-rsync.timer (03:45 — after the 03:30
# hermes-insurance run, before the hypervisor's 04:00 restic→GCS
# window): mirror the FULL ~/.hermes tree to the NFS-mounted
# bezapool/brizza-backup dataset.
#
# Why the full tree: the live state.db copy can be torn mid-write
# (SQLite-WAL), but that's acceptable — restore uses the CONSISTENT
# state-snapshots/<ts>-nightly/ dirs that hermes-insurance produces
# inside this same tree, plus the sessions-*.jsonl exports. Carrying
# everything means nothing (workspace, media, local bin) is left
# behind.
#
# Runs as root: ~/.hermes contents are uid-10000 (container user);
# --numeric-ids + the export's no_root_squash preserve ownership raw,
# so a restore rsync back is byte-faithful.
#
# Downstream: sanoid snapshots bezapool/brizza-backup daily (03:00 —
# captures the PREVIOUS night's mirror; same-night durability comes
# from restic reading the live dataset at 04:00) and restic ships it
# to GCS Nearline.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/forge-brizza/templates/hermes-backup-rsync.sh.j2

set -uo pipefail

SRC="{{ forge_brizza_hermes_backup_src }}"
DEST_MOUNT="{{ forge_brizza_hermes_backup_mount }}"
DEST="{{ forge_brizza_hermes_backup_dest }}"

# Sanity: never rsync --delete into an unmounted mountpoint (would
# mirror into the empty local dir and a later mount would shadow it).
if ! mountpoint -q "${DEST_MOUNT}"; then
    echo "FATAL: ${DEST_MOUNT} is not a mountpoint. NFS down?" >&2
    logger -t hermes-backup-rsync "FATAL: ${DEST_MOUNT} not mounted — skipped"
    exit 2
fi

if [[ ! -d "${SRC}" ]]; then
    echo "FATAL: ${SRC} does not exist." >&2
    logger -t hermes-backup-rsync "FATAL: ${SRC} missing — skipped"
    exit 2
fi

mkdir -p "${DEST}"

# Flags match the forge-ops backup rsync:
# -a / -H / -X   : archive + hard links + xattrs
# --delete       : mirror tracks source; sanoid snapshots keep history
# --numeric-ids  : preserve raw uid/gid (uid-10000 container files)
# Baseline excludes: runtime droppings only — never state.
if rsync -aHX --delete --numeric-ids --info=stats1 \
    --exclude='*.tmp' \
    --exclude='*.lock' \
    --exclude='*.pid' \
    --exclude='*.swp' \
    "${SRC}/" "${DEST}/"; then
    logger -t hermes-backup-rsync "ok: ${SRC} → ${DEST} ($(du -sh "${DEST}" | cut -f1))"
    echo "Backup completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
else
    rc=$?
    logger -t hermes-backup-rsync "FAIL: rsync exit ${rc}"
    echo "FAIL: rsync exit ${rc}" >&2
    exit 1
fi
