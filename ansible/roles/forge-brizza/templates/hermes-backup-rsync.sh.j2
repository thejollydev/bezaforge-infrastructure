#!/usr/bin/env bash
# {{ ansible_managed }}
# hermes-backup-rsync — Brizza off-VM durability (FORGE-25).
#
# Nightly (03:45 — after the 03:30 hermes-insurance run, before the
# hypervisor's 04:00 restic→GCS window): rsync the ~/.hermes tree to
# bezapool/brizza-backup on forge-hypervisor, OVER SSH.
#
# Why SSH and not NFS: forge-brizza's NFS client EINVALs on recursive
# directory traversal (FORGE-49; re-confirmed FORGE-25 2026-06-12 on a
# write-only target with no git actor), which breaks rsync --delete —
# it must scan the destination tree. Over SSH the remote rsync runs ON
# the hypervisor against the LOCAL ZFS path (no NFS in the path), so
# --delete + --delete-excluded work cleanly.
#
# Runs as root: ~/.hermes contents are uid-10000; rsync reads them
# locally as root, the remote rsync writes as root on the hypervisor,
# and --numeric-ids preserves ownership across the wire.
#
# DO NOT EDIT THIS FILE BY HAND.
# Source of truth: ansible/roles/forge-brizza/templates/hermes-backup-rsync.sh.j2

set -uo pipefail

SRC="{{ forge_brizza_hermes_backup_src }}"
DEST_HOST="{{ forge_brizza_hermes_backup_dest_host }}"
DEST_USER="{{ forge_brizza_hermes_backup_dest_user }}"
DEST_PATH="{{ forge_brizza_hermes_backup_dest_path }}"
SSH_KEY="{{ forge_brizza_hermes_backup_ssh_key }}"
DATASET_MOUNT="$(dirname "${DEST_PATH}")"

SSH_OPTS="-i ${SSH_KEY} -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10"

if [[ ! -d "${SRC}" ]]; then
    echo "FATAL: ${SRC} does not exist." >&2
    logger -t hermes-backup-rsync "FATAL: ${SRC} missing — skipped"
    exit 2
fi

# Preflight: SSH reachable AND the backup dataset is mounted on the
# hypervisor (guards against rsyncing into a bare mountpoint if the pool
# is offline). Also ensures the dest dir exists.
if ! ssh ${SSH_OPTS} "${DEST_USER}@${DEST_HOST}" \
        "mountpoint -q '${DATASET_MOUNT}' && mkdir -p '${DEST_PATH}'"; then
    echo "FATAL: ssh to ${DEST_USER}@${DEST_HOST} failed or ${DATASET_MOUNT} not mounted." >&2
    logger -t hermes-backup-rsync "FATAL: preflight failed (ssh/${DEST_HOST} or ${DATASET_MOUNT})"
    exit 2
fi

# Flags match the forge-ops backup rsync:
# -a / -H / -X       : archive + hard links + xattrs
# --delete           : mirror tracks source; sanoid snapshots keep history
# --delete-excluded  : also purge excluded paths from the dest, so the
#                      mirror is an exact image of the included set
# --numeric-ids      : preserve raw uid/gid (uid-10000 container files)
# Baseline excludes: runtime droppings only — never state.
if rsync -aHX --delete --delete-excluded --numeric-ids --info=stats1 \
    -e "ssh ${SSH_OPTS}" \
    --exclude='*.tmp' \
    --exclude='*.lock' \
    --exclude='*.pid' \
    --exclude='*.swp' \
{% for ex in forge_brizza_hermes_backup_excludes %}
    --exclude='{{ ex }}' \
{% endfor %}
    "${SRC}/" "${DEST_USER}@${DEST_HOST}:${DEST_PATH}/"; then
    logger -t hermes-backup-rsync "ok: ${SRC} → ${DEST_HOST}:${DEST_PATH}"
    echo "Backup completed at $(date -u +%Y-%m-%dT%H:%M:%SZ)."
else
    rc=$?
    logger -t hermes-backup-rsync "FAIL: rsync exit ${rc}"
    echo "FAIL: rsync exit ${rc}" >&2
    exit 1
fi
